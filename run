#!/usr/bin/env bash
# run — single entrypoint for building, starting, and tailing the
# devin-issue-remediation stack. Hides docker-compose behind verbose,
# human-friendly terminal output so operators never need to remember
# container names, build flags, or log commands.
#
# Usage:
#   ./run [--quiet] <command> [extra args...]
#
# Run `./run help` for the full command reference.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# -------- flags -----------------------------------------------------------
QUIET=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -q|--quiet) QUIET=1; shift ;;
    -v|--verbose) QUIET=0; shift ;; # default is already verbose; accepted for clarity
    --) shift; break ;;
    *) break ;;
  esac
done

CMD="${1:-help}"
shift || true

# -------- colors / section headers ---------------------------------------
if [[ -t 1 ]]; then
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'; C_CYAN=$'\033[36m'
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_DIM=""; C_CYAN=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_RESET=""
fi

section() { printf '\n%s=== %s ===%s\n' "$C_BOLD$C_CYAN" "$*" "$C_RESET"; }
info()    { printf '%s[run]%s %s\n' "$C_CYAN" "$C_RESET" "$*"; }
warn()    { printf '%s[run]%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()     { printf '%s[run]%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }
ok()      { printf '%s[run]%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }

# -------- compose abstraction --------------------------------------------
# Detect whichever compose variant is installed. We never call `docker` or
# `docker-compose` directly outside this helper so the rest of the script
# stays portable.
detect_compose() {
  if docker compose version >/dev/null 2>&1; then
    COMPOSE=(docker compose)
  elif command -v docker-compose >/dev/null 2>&1; then
    COMPOSE=(docker-compose)
  else
    err "Docker Compose is not installed. Install Docker Desktop from https://docs.docker.com/get-docker/ and retry."
    exit 127
  fi
}

check_daemon() {
  if ! docker info >/dev/null 2>&1; then
    err "Cannot reach the Docker daemon. Start Docker Desktop (or 'sudo systemctl start docker') and retry."
    exit 125
  fi
}

check_env_file() {
  if [[ ! -f .env ]]; then
    err ".env is missing. Copy .env.example to .env and fill in the four required values."
    err "  cp .env.example .env"
    exit 2
  fi
}

compose() {
  "${COMPOSE[@]}" "$@"
}

# When verbose (default), surface full BuildKit step output and plumb a
# DEBUG-level app log through to the container via env vars that the app
# and Dockerfile both consult.
build_env() {
  if [[ $QUIET -eq 1 ]]; then
    BUILDKIT_PROGRESS=auto
    APP_LOG_LEVEL=info
  else
    BUILDKIT_PROGRESS=plain
    APP_LOG_LEVEL=debug
  fi
  export DOCKER_BUILDKIT=1
  export BUILDKIT_PROGRESS
  export LOG_LEVEL="$APP_LOG_LEVEL"
  export UVICORN_LOG_LEVEL="$APP_LOG_LEVEL"
}

# -------- commands --------------------------------------------------------
cmd_build() {
  section "Building images"
  build_env
  if [[ $QUIET -eq 0 ]]; then
    compose build --progress=plain "$@"
  else
    compose build "$@"
  fi
  ok "Build complete."
}

cmd_stop() {
  section "Stopping containers"
  detect_compose
  compose down "$@"
  ok "Stopped."
}

cmd_restart() {
  section "Restarting containers"
  detect_compose
  compose restart "$@"
  compose ps
}

cmd_rebuild() {
  section "Rebuilding from scratch (no cache)"
  build_env
  compose build --no-cache --progress=plain "$@"
  ok "Rebuild complete. Run './run start' to launch."
}

cmd_logs() {
  local view="${1:-app}"
  section "Logs — ${view}"
  case "$view" in
    app)
      # Clean Devin status events only — session started, blocked, finished,
      # errors, PR merged. Same output as the old ./run --quiet start.
      compose logs -f --tail=200 --timestamps app \
        | grep --line-buffered -E \
            "(ERROR|WARNING|Devin|Issue|issue|session|Session|PR|Relay|WEBHOOK|Accepted|failed)"
      ;;
    all)
      # Every log line from every container — useful when debugging webhook
      # delivery or ngrok connectivity.
      compose logs -f --tail=200 --timestamps
      ;;
    raw)
      # Unfiltered app container logs — includes DEBUG lines if the container
      # was started with LOG_LEVEL=debug.
      compose logs -f --tail=200 --timestamps app
      ;;
    ngrok)
      # Tunnel logs only — shows incoming HTTP requests from GitHub.
      compose logs -f --tail=200 --timestamps ngrok
      ;;
    *)
      err "Unknown log view: ${view}"
      info "Available views: app (default), all, raw, ngrok"
      exit 64
      ;;
  esac
}

cmd_status() {
  section "Container status"
  detect_compose
  compose ps
  section "Resource usage"
  # --no-stream prints a single snapshot instead of a live TUI so the
  # output is scriptable and always returns to the prompt. The unquoted
  # command substitution is intentional: docker stats expects each
  # container id as a separate positional argument, so we rely on
  # bash word-splitting the newline-separated ids from `compose ps -q`.
  local ids
  ids=$(compose ps -q 2>/dev/null || true)
  if [[ -n "$ids" ]]; then
    # shellcheck disable=SC2086
    docker stats --no-stream $ids || true
  else
    info "No containers running."
  fi
}

cmd_shell() {
  section "Opening shell in app container"
  detect_compose
  local service="${1:-app}"
  compose exec "$service" /bin/sh
}

cmd_help() {
  cat <<EOF
${C_BOLD}devin-issue-remediation — ./run${C_RESET}

A single terminal entrypoint for the whole stack. You never need to invoke
docker or docker compose directly.

${C_BOLD}Usage:${C_RESET}
  ./run [--quiet] <command> [args...]

${C_BOLD}Starting the stack:${C_RESET}
  docker compose up --build        # build + start (foreground, Ctrl+C stops)
  docker compose up --build -d     # same but detached (use ./run logs to follow)

${C_BOLD}Commands:${C_RESET}
  logs [view]  Tail logs from the running stack. Views:
                 app    (default) Devin status events — session started/blocked/
                        finished/error, PRs merged. Clean signal, low noise.
                 all    Every log line from every container.
                 raw    Unfiltered app container logs (includes DEBUG if enabled).
                 ngrok  Tunnel logs — incoming webhook requests from GitHub.
  stop         Stop and remove containers (volumes preserved).
  restart      Restart running containers without rebuilding.
  rebuild      Force a clean no-cache rebuild.
  build        Build images only (do not start containers).
  status       Show container and resource usage.
  shell        Open an interactive shell inside the app container.
  help         Show this help text.

${C_BOLD}Examples:${C_RESET}
  docker compose up --build        # start the stack
  ./run logs                       # Devin status events (clean view)
  ./run logs all                   # everything, all containers
  ./run logs raw                   # unfiltered app logs
  ./run logs ngrok                 # incoming webhook requests
  ./run rebuild                    # no-cache rebuild
  ./run shell                      # shell inside app container
EOF
}

# -------- dispatch --------------------------------------------------------
case "$CMD" in
  stop|down)    detect_compose; check_daemon; cmd_stop "$@" ;;
  restart)      detect_compose; check_daemon; cmd_restart "$@" ;;
  rebuild)      detect_compose; check_daemon; check_env_file; cmd_rebuild "$@" ;;
  build)        detect_compose; check_daemon; check_env_file; cmd_build "$@" ;;
  logs)         detect_compose; check_daemon; cmd_logs "$@" ;;
  status|ps)    detect_compose; check_daemon; cmd_status "$@" ;;
  shell|exec)   detect_compose; check_daemon; cmd_shell "$@" ;;
  help|-h|--help) cmd_help ;;
  *)
    err "Unknown command: $CMD"
    cmd_help
    exit 64
    ;;
esac
