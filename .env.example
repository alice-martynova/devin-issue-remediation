# Devin API key — get from https://app.devin.ai/settings/api-keys
DEVIN_API_KEY=your_devin_api_key_here

# GitHub Personal Access Token — needs repo + issues scopes
GITHUB_TOKEN=your_github_pat_here

# Secret used to verify GitHub webhook payloads (set when registering webhook)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ngrok auth token — get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# How often (seconds) to poll active Devin sessions for status updates
POLL_INTERVAL_SECONDS=60

# --- Trigger filters (all optional; leave unset to act on every issue) ---
# Only fire on issues that carry at least one of these labels (comma-separated).
# Matching is case-insensitive. Example: TRIGGER_LABELS=devin,auto-fix
TRIGGER_LABELS=

# Only fire on issues whose title starts with this prefix (case-insensitive).
# Example: TRIGGER_TITLE_PREFIX=[devin]
TRIGGER_TITLE_PREFIX=

# --- PR behavior ---
# If truthy (1/true/yes/on), instruct Devin to open the PR as a draft.
DRAFT_PR=

# Comma-separated GitHub usernames to request review from on each PR Devin
# opens. Example: PR_REVIEWERS=alice,bob
PR_REVIEWERS=
